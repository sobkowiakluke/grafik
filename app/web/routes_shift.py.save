from flask import Blueprint, render_template, request, redirect, url_for, flash
from flask_login import login_required
from app.db.provider import get_db


shift_bp = Blueprint("shift", __name__, url_prefix="/shifts")


@shift_bp.route("/new")
@login_required
def new_shift():

    db = get_db()
    cur = db.cursor()

    # pracownicy
    cur.execute("""
        SELECT id, first_name, last_name
        FROM employees
        WHERE active = 1
        ORDER BY last_name, first_name
    """)
    employees = cur.fetchall()

    # grafiki (zgodnie ze schematem year/month)
    cur.execute("""
        SELECT id, year, month
        FROM schedules
        ORDER BY year DESC, month DESC
    """)
    schedules = cur.fetchall()

    cur.close()

    return render_template(
        "shift_form.html",
        employees=employees,
        schedules=schedules
    )


@shift_bp.route("", methods=["POST"])
@login_required
def create_shift():

    from datetime import datetime

    schedule_id = request.form.get("schedule_id")
    employee_id = request.form.get("employee_id")
    shift_date = request.form.get("work_date")
    start_time = request.form.get("start_time")
    end_time = request.form.get("end_time")

    

    if not schedule_id:
        flash("Wybierz grafik", "danger")
        return redirect(url_for("shift.new_shift"))

    if not employee_id:
        flash("Wybierz pracownika", "danger")
        return redirect(url_for("shift.new_shift"))

    db = get_db()
    cur = db.cursor()

    # --- WALIDACJA DATY VS GRAFIK ---
    cur.execute("""
        SELECT year, month
        FROM schedules
        WHERE id = %s
    """, (schedule_id,))

    schedule = cur.fetchone()

    if not schedule:
        flash("Nieprawidłowy grafik", "danger")
        cur.close()
        return redirect(url_for("shift.new_shift"))

    try:
        parsed_date = datetime.strptime(shift_date, "%Y-%m-%d")
    except ValueError:
        flash("Nieprawidłowa data", "danger")
        cur.close()
        return redirect(url_for("shift.new_shift"))

    if parsed_date.year != schedule["year"] or parsed_date.month != schedule["month"]:
        flash("Data nie należy do wybranego miesiąca grafiku", "danger")
        cur.close()
        return redirect(url_for("shift.new_shift"))

    # --- INSERT ---
    cur.execute("""
        INSERT INTO shifts (
            schedule_id,
            employee_id,
            shift_date,
            start_time,
            end_time
        )
        VALUES (%s, %s, %s, %s, %s)
    """, (
        schedule_id,
        employee_id,
        shift_date,
        start_time,
        end_time
    ))

    db.commit()
    cur.close()

    return redirect(
        url_for(
            "schedule_bp.schedule_details",
            schedule_id=schedule_id
        )
    )
